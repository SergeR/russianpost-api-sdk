{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pochta.ru PUT Timeslot Booking by PoistIndex API Schema",
  "description": "JSON Schema для API бронирования временного слота по почтовому индексу Почты России",
  "definitions": {
    "request": {
      "type": "object",
      "description": "Структура запроса для бронирования временного слота",
      "properties": {
        "barcode": {
          "type": "string",
          "description": "ШПИ отправления. Текстовая строка от 13 до 50 символов",
          "minLength": 13,
          "maxLength": 50
        },
        "contractNumber": {
          "type": "string",
          "description": "Номер договора (максимальная длина 50 символов)",
          "maxLength": 50
        }
      },
      "required": [
        "barcode",
        "contractNumber"
      ],
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "description": "Структура ответа с информацией об ошибках",
      "properties": {
        "code": {
          "type": "string",
          "description": "Текстовый идентификатор ошибки"
        },
        "message": {
          "type": "string",
          "description": "Подробное описание ошибки поля входных данных"
        },
        "errors": {
          "type": "array",
          "description": "Возвращается при наличии ошибок в полях входных данных",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "description": "Текстовый идентификатор поля входных данных"
              },
              "message": {
                "type": "string",
                "description": "Подробное описание ошибки поля входных данных"
              }
            },
            "required": [
              "field",
              "message"
            ],
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
