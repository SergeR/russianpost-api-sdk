{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pochta.ru Orders in Shipment API Schema",
  "description": "JSON Schema для API Почты России - получение заказов в партии",
  "type": "object",
  "definitions": {
    "response": {
      "type": "array",
      "description": "Массив отправлений в партии",
      "items": {
        "type": "object",
        "properties": {
          "add-to-mmo": {
            "type": "boolean",
            "description": "Отметка 'Добавить в многоместное отправление'"
          },
          "address-changed": {
            "type": "boolean",
            "description": "Адрес получателя скорректирован в процессе очистки"
          },
          "address-type-from": {
            "type": "string",
            "description": "Тип адреса отправителя"
          },
          "address-type-to": {
            "type": "string",
            "description": "Тип адреса получателя"
          },
          "area-from": {
            "type": "string",
            "description": "Район отправителя"
          },
          "area-to": {
            "type": "string",
            "description": "Район"
          },
          "arrival-date": {
            "type": "string",
            "description": "Дата прибытия отправления в место вручения"
          },
          "avia-rate": {
            "type": "integer",
            "description": "Авиа-сбор без НДС (для совместимости)"
          },
          "avia-rate-with-vat": {
            "type": "integer",
            "description": "Авиа-сбор с НДС"
          },
          "avia-rate-wo-vat": {
            "type": "integer",
            "description": "Авиа-сбор без НДС"
          },
          "barcode": {
            "type": "string",
            "description": "ШПИ"
          },
          "batch-category": {
            "type": "string",
            "description": "Категория партии"
          },
          "batch-name": {
            "type": "string",
            "description": "Внешний идентификатор партии заказа"
          },
          "batch-status": {
            "type": "string",
            "description": "Статус партии"
          },
          "bk-hash": {
            "type": "integer",
            "description": "Хэш-код"
          },
          "branch-name": {
            "type": "string",
            "description": "Идентификатор подразделения"
          },
          "building-from": {
            "type": "string",
            "description": "Часть здания: Строение отправителя"
          },
          "building-to": {
            "type": "string",
            "description": "Часть здания: Строение"
          },
          "comment": {
            "type": "string",
            "description": "Комментарий к заказу"
          },
          "completeness-checking": {
            "type": "boolean",
            "description": "Признак услуги проверки комплектности"
          },
          "completeness-checking-rate-with-vat": {
            "type": "integer",
            "description": "Надбавка за \"Проверку комплектности\" с НДС"
          },
          "completeness-checking-rate-wo-vat": {
            "type": "integer",
            "description": "Надбавка за \"Проверку комплектности\" без НДС"
          },
          "compulsory-payment": {
            "type": "integer",
            "description": "К оплате с получателя (копейки)"
          },
          "contents-checking-rate-with-vat": {
            "type": "integer",
            "description": "Надбавка за \"Проверку вложений\" с НДС"
          },
          "contents-checking-rate-wo-vat": {
            "type": "integer",
            "description": "Надбавка за \"Проверку вложений\" без НДС"
          },
          "corpus-from": {
            "type": "string",
            "description": "Часть здания: Корпус отправителя"
          },
          "corpus-to": {
            "type": "string",
            "description": "Часть здания: Корпус"
          },
          "customs-declaration": {
            "type": "object",
            "description": "Таможенная декларация",
            "properties": {
              "certificate-number": {
                "type": "string",
                "description": "Сертификаты, сопровождающие отправление"
              },
              "comments": {
                "type": "string",
                "description": "Комментарии"
              },
              "currency": {
                "type": "string",
                "description": "Код валюты"
              },
              "customs-code": {
                "type": "string",
                "description": "Код таможенного органа"
              },
              "customs-comments": {
                "type": "string",
                "description": "Комментарии таможенного органа"
              },
              "customs-decision": {
                "type": "string",
                "description": "Решение таможенного органа",
                "enum": [
                  "REJECTION",
                  "RELEASE_WO_CUSTOMS_DUTY",
                  "CUSTOMS_DUTY_REQUIRED",
                  "CUSTOMS_CONTROL_REQUIRED",
                  "RESERVE",
                  "RELEASE_SUSPENDED",
                  "RELEASE_PERIOD_PROLONGED",
                  "RELEASE_CUSTOMS_DUTY_PAID",
                  "AUTO_RELEASE_RETURN_GOODS",
                  "RELEASE_RETURN_GOODS",
                  "REJECTION_AUTO_RELEASE",
                  "DEPARTURE_ALLOWED",
                  "DEPARTURE_DENIED"
                ]
              },
              "customs-entries": {
                "type": "array",
                "description": "Список вложений",
                "items": {
                  "type": "object",
                  "properties": {
                    "amount": {
                      "type": "integer",
                      "description": "Количество"
                    },
                    "country-code": {
                      "type": "integer",
                      "description": "Код страны происхождения"
                    },
                    "description": {
                      "type": "string",
                      "description": "Наименование товара"
                    },
                    "entry-number": {
                      "type": "integer",
                      "description": "Порядковый номер"
                    },
                    "tnved-code": {
                      "type": "string",
                      "description": "Код ТНВЭД"
                    },
                    "trademark": {
                      "type": "string",
                      "description": "Торговая марка"
                    },
                    "value": {
                      "type": "integer",
                      "description": "Цена за единицу товара в копейках (вкл. НДС)"
                    },
                    "weight": {
                      "type": "integer",
                      "description": "Вес товара (в граммах)"
                    }
                  },
                  "required": ["amount", "description", "entry-number", "tnved-code"]
                }
              },
              "decision-date": {
                "type": "string",
                "description": "Дата решения таможенного органа"
              },
              "decision-description": {
                "type": "string",
                "description": "Описание решения таможенного органа"
              },
              "entries-type": {
                "type": "string",
                "description": "Категория вложения"
              },
              "fts-error": {
                "type": "string",
                "description": "Ошибка декларирования"
              },
              "invoice-number": {
                "type": "string",
                "description": "Счет (номер счета-фактуры)"
              },
              "ioss-code": {
                "type": "string",
                "description": "Регистрационный код продавца"
              },
              "license-number": {
                "type": "string",
                "description": "Лицензии, сопровождающие отправление"
              },
              "recom-description": {
                "type": "string",
                "description": "Описание рекомендации таможенного органа"
              },
              "registration-date": {
                "type": "string",
                "description": "Дата регистрации документа таможенным органом"
              },
              "status": {
                "type": "string",
                "description": "Статус декларации в процессе электронного декларирования",
                "enum": ["NEW", "TRANSIT", "IN_PROGRESS", "DONE", "REJECTED", "CANCELED", "ILLEGAL_DATA", "FTS_ERROR"]
              },
              "with-certificate": {
                "type": "boolean",
                "description": "Приложенные документы: сертификат"
              },
              "with-invoice": {
                "type": "boolean",
                "description": "Приложенные документы: счет-фактура"
              },
              "with-license": {
                "type": "boolean",
                "description": "Приложенные документы: лицензия"
              }
            },
            "required": ["currency", "customs-entries", "entries-type"]
          },
          "declaration-status": {
            "type": "string",
            "description": "Результат электронного декларирования"
          },
          "delivery-time": {
            "type": "object",
            "description": "Время доставки",
            "properties": {
              "max-days": {
                "type": "integer",
                "description": "Максимальное время доставки (дни)"
              },
              "min-days": {
                "type": "integer",
                "description": "Минимальное время доставки (дни)"
              }
            },
            "required": ["max-days"]
          },
          "delivery-with-cod": {
            "type": "boolean",
            "description": "Признак оплаты при получении"
          },
          "dimension": {
            "type": "object",
            "description": "Линейные размеры",
            "properties": {
              "height": {
                "type": "integer",
                "description": "Линейная высота (сантиметры)"
              },
              "length": {
                "type": "integer",
                "description": "Линейная длина (сантиметры)"
              },
              "width": {
                "type": "integer",
                "description": "Линейная ширина (сантиметры)"
              }
            }
          },
          "dimension-type": {
            "type": "string",
            "description": "Типоразмер"
          },
          "easy-return-rate-with-vat": {
            "type": "integer",
            "description": "Сбор за \"Лёгкий возврат\" с НДС"
          },
          "easy-return-rate-wo-vat": {
            "type": "integer",
            "description": "Сбор за \"Лёгкий возврат\" без НДС"
          },
          "ecom-data": {
            "type": "object",
            "description": "Данные ЕКОМ",
            "properties": {
              "delivery-point-index": {
                "type": "string",
                "description": "Идентификатор пункта выдачи"
              },
              "delivery-point-type": {
                "type": "string",
                "description": "Тип пункта выдачи"
              },
              "identity-methods": {
                "type": "array",
                "description": "Методы идентификации личности",
                "items": {
                  "type": "string"
                }
              },
              "services": {
                "type": "array",
                "description": "Коды видов сервиса",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "electronic-notification-history": {
            "type": "object",
            "description": "История электронной нотификации",
            "properties": {
              "items": {
                "type": "array",
                "description": "Список вложений",
                "items": {
                  "type": "object",
                  "properties": {
                    "has-external-resource": {
                      "type": "boolean",
                      "description": "Признак наличия внешнего ресурса"
                    },
                    "is-download": {
                      "type": "boolean",
                      "description": "Признак скачивался ли ЭУВ клиентом"
                    },
                    "oper-attr": {
                      "type": "integer",
                      "description": "Атрибут операции"
                    },
                    "oper-date": {
                      "type": "string",
                      "description": "Дата и время операции"
                    },
                    "oper-type": {
                      "type": "integer",
                      "description": "Тип операции"
                    }
                  },
                  "required": ["oper-date", "oper-type"]
                }
              }
            },
            "required": ["items"]
          },
          "envelope-type": {
            "type": "string",
            "description": "Тип конверта - ГОСТ Р 51506-99"
          },
          "fiscal-data": {
            "type": "object",
            "description": "Фискальные данные",
            "properties": {
              "customer-email": {
                "type": "string",
                "description": "Адрес электронной почты плательщика"
              },
              "customer-inn": {
                "type": "string",
                "description": "ИНН юридического лица покупателя"
              },
              "customer-name": {
                "type": "string",
                "description": "Наименование юридического лица покупателя"
              },
              "customer-phone": {
                "type": "integer",
                "description": "Телефон плательщика"
              },
              "fiscal-payments": {
                "type": "array",
                "description": "Средства, использованные при оплате",
                "items": {
                  "type": "object",
                  "properties": {
                    "payment-amount": {
                      "type": "integer",
                      "description": "Сумма оплаты платежным средством,(копейки)"
                    },
                    "payment-kind": {
                      "type": "integer",
                      "description": "Вид платежного средства"
                    },
                    "payment-type": {
                      "type": "integer",
                      "description": "Тип платежного средства"
                    }
                  }
                }
              }
            }
          },
          "fragile-rate-with-vat": {
            "type": "integer",
            "description": "Надбавка за отметку \"Осторожно/Хрупкое/Терморежим\""
          },
          "fragile-rate-wo-vat": {
            "type": "integer",
            "description": "Надбавка за отметку \"Осторожно/Хрупкое/Терморежим\" без НДС"
          },
          "functionality-checking-rate-with-vat": {
            "type": "integer",
            "description": "Надбавка за \"Проверку вложений с проверкой работоспособности\" с НДС"
          },
          "functionality-checking-rate-wo-vat": {
            "type": "integer",
            "description": "Надбавка за \"Проверку вложений с проверкой работоспособности\" без НДС"
          },
          "given-name": {
            "type": "string",
            "description": "Имя получателя"
          },
          "goods": {
            "type": "object",
            "description": "Товарное вложение РПО",
            "properties": {
              "items": {
                "type": "array",
                "description": "Список вложений",
                "items": {
                  "type": "object",
                  "properties": {
                    "category-feature": {
                      "type": "string",
                      "description": "Категория товара"
                    },
                    "code": {
                      "type": "string",
                      "description": "Код (маркировка) товара"
                    },
                    "country-code": {
                      "type": "integer",
                      "description": "Код страны происхождения"
                    },
                    "customs-declaration-number": {
                      "type": "string",
                      "description": "Номер таможенной декларации"
                    },
                    "description": {
                      "type": "string",
                      "description": "Наименование товара"
                    },
                    "excise": {
                      "type": "integer",
                      "description": "Акциз (копейки)"
                    },
                    "id": {
                      "type": "integer",
                      "description": "Номер товара в списке вложений"
                    },
                    "good-id": {
                      "type": "string",
                      "description": "внутренний идентификатор товара у поставщика"
                    },
                    "goods-type": {
                      "type": "string",
                      "description": "Признак товар или услуга"
                    },
                    "insr-value": {
                      "type": "integer",
                      "description": "Объявленная ценность (копейки)"
                    },
                    "item-number": {
                      "type": "string",
                      "description": "Номенклатура (артикул) товара"
                    },
                    "lineattr": {
                      "type": "integer",
                      "description": "Признак предмета расчета"
                    },
                    "payattr": {
                      "type": "integer",
                      "description": "Признак способа расчета"
                    },
                    "quantity": {
                      "type": "number",
                      "description": "Количество товара"
                    },
                    "returned": {
                      "type": "boolean",
                      "description": "Статус возврата, вложения(ЕКОМ)"
                    },
                    "service-type": {
                      "type": "integer",
                      "description": "Вид сервиса для товара: 1 - без вскрытия (по умолчанию), 2 - с осмотром вложения, 3 - с примеркой"
                    },
                    "supplier-inn": {
                      "type": "string",
                      "description": "ИНН поставщика товара"
                    },
                    "supplier-name": {
                      "type": "string",
                      "description": "Наименование поставщика товара"
                    },
                    "supplier-phone": {
                      "type": "string",
                      "description": "Телефон поставщика товара"
                    },
                    "value": {
                      "type": "integer",
                      "description": "Цена за единицу товара в копейках (вкл. НДС)"
                    },
                    "vat-rate": {
                      "type": "integer",
                      "description": "Ставка НДС: Без НДС(-1), 0, 10, 110, 20, 120"
                    },
                    "weight": {
                      "type": "integer",
                      "description": "Вес товара (в граммах)"
                    }
                  },
                  "required": ["description", "id", "quantity"]
                }
              }
            },
            "required": ["items"]
          },
          "ground-rate": {
            "type": "integer",
            "description": "Сбор за доставку наземно без НДС (для совместимости)"
          },
          "ground-rate-with-vat": {
            "type": "integer",
            "description": "Сбор за доставку наземно с НДС"
          },
          "ground-rate-wo-vat": {
            "type": "integer",
            "description": "Сбор за доставку наземно без НДС"
          },
          "group-name": {
            "type": "string",
            "description": "Наименование группы (для Многоместных отправлений см. ММО)"
          },
          "hotel-from": {
            "type": "string",
            "description": "Название гостиницы отправителя"
          },
          "hotel-to": {
            "type": "string",
            "description": "Название гостиницы"
          },
          "house-from": {
            "type": "string",
            "description": "Часть адреса: Номер здания отправителя"
          },
          "house-to": {
            "type": "string",
            "description": "Часть адреса: Номер здания"
          },
          "human-operation-name": {
            "type": "string",
            "description": "Наименование операции"
          },
          "hyper-local-status": {
            "type": "string",
            "description": "Статус по гиперлокальной доставке"
          },
          "id": {
            "type": "integer",
            "description": "Внутренний идентификатор отправления"
          },
          "in-mmo": {
            "type": "boolean",
            "description": "Отправление в составе ММО"
          },
          "index-from": {
            "type": "string",
            "description": "Почтовый индекс отправителя"
          },
          "index-to": {
            "type": "integer",
            "description": "Почтовый индекс"
          },
          "inner-num": {
            "type": "string",
            "description": "Дополнительный идентификатор отправления"
          },
          "insr-rate": {
            "type": "integer",
            "description": "Плата за ОЦ без НДС (для совместимости)"
          },
          "insr-rate-with-vat": {
            "type": "integer",
            "description": "Плата за ОЦ с НДС"
          },
          "insr-rate-wo-vat": {
            "type": "integer",
            "description": "Плата за ОЦ без НДС"
          },
          "insr-value": {
            "type": "integer",
            "description": "Объявленная ценность (копейки)"
          },
          "inventory-rate-with-vat": {
            "type": "integer",
            "description": "Надбавка за \"Опись вложения\" с НДС"
          },
          "inventory-rate-wo-vat": {
            "type": "integer",
            "description": "Надбавка за \"Опись вложения\" без НДС"
          },
          "is-deleted": {
            "type": "boolean",
            "description": "Заказ удален?"
          },
          "last-oper-attr": {
            "type": "string",
            "description": "Атрибут последней операции из трекинга"
          },
          "last-oper-date": {
            "type": "string",
            "description": "Дата получения статуса"
          },
          "last-oper-type": {
            "type": "string",
            "description": "Тип последней операции из трекинга"
          },
          "legal-hid": {
            "type": "string",
            "description": "Почта ID HID юридического лица"
          },
          "letter-from": {
            "type": "string",
            "description": "Часть здания: Литера отправителя"
          },
          "letter-to": {
            "type": "string",
            "description": "Часть здания: Литера"
          },
          "linked-barcode": {
            "type": "string",
            "description": "ШПИ связанного отправления"
          },
          "location-from": {
            "type": "string",
            "description": "Микрорайон отправителя"
          },
          "location-to": {
            "type": "string",
            "description": "Микрорайон"
          },
          "mail-category": {
            "type": "string",
            "description": "Категория РПО"
          },
          "mail-direct": {
            "type": "integer",
            "description": "Код страны"
          },
          "mail-rank": {
            "type": "string",
            "description": "Код разряда почтового отправления"
          },
          "mail-type": {
            "type": "string",
            "description": "Вид РПО"
          },
          "mass": {
            "type": "integer",
            "description": "Вес РПО (в граммах)"
          },
          "mass-rate": {
            "type": "integer",
            "description": "Почтовый сбор без НДС (для совместимости)"
          },
          "mass-rate-with-vat": {
            "type": "integer",
            "description": "Почтовый сбор с НДС"
          },
          "mass-rate-wo-vat": {
            "type": "integer",
            "description": "Почтовый сбор без НДС"
          },
          "middle-name": {
            "type": "string",
            "description": "Отчество получателя"
          },
          "mpo-declaration": {
            "type": "string",
            "description": "Данные таможенной декларации в формате XML (кодировка UTF-8, структура согласно РТМ 0030.14-16 [4]), закодированные в строку Base64"
          },
          "notice-payment-method": {
