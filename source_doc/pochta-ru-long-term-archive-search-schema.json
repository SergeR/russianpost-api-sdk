    "customsDeclaration": {
      "type": "object",
      "description": "Таможенная декларация",
      "required": [
        "currency",
        "customs-entries",
        "entries-type"
      ],
      "properties": {
        "certificate-number": {
          "type": "string",
          "description": "Сертификаты, сопровождающие отправление"
        },
        "comments": {
          "type": "string",
          "description": "Комментарии"
        },
        "currency": {
          "type": "string",
          "description": "Код валюты"
        },
        "customs-code": {
          "type": "string",
          "description": "Код таможенного органа"
        },
        "customs-comments": {
          "type": "string",
          "description": "Комментарии таможенного органа"
        },
        "customs-decision": {
          "type": "string",
          "description": "Решение таможенного органа",
          "enum": [
            "REJECTION",
            "RELEASE_WO_CUSTOMS_DUTY",
            "CUSTOMS_DUTY_REQUIRED",
            "CUSTOMS_CONTROL_REQUIRED",
            "RESERVE",
            "RELEASE_SUSPENDED",
            "RELEASE_PERIOD_PROLONGED",
            "RELEASE_CUSTOMS_DUTY_PAID",
            "AUTO_RELEASE_RETURN_GOODS",
            "RELEASE_RETURN_GOODS",
            "REJECTION_AUTO_RELEASE",
            "DEPARTURE_ALLOWED",
            "DEPARTURE_DENIED"
          ]
        },
        "customs-entries": {
