{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pochta-ru-user-shipping-points-schema.json",
  "title": "Почта России - Точки сдачи",
  "description": "Схема ответа API для получения точек сдачи отправлений Почты России",
  "definitions": {
    "product": {
      "type": "object",
      "description": "Доступный продукт",
      "properties": {
        "mail-category": {
          "type": "string",
          "description": "Категория РПО"
        },
        "mail-type": {
          "type": "string",
          "description": "Вид РПО"
        },
        "product-type": {
          "type": "string",
          "description": "Тип продукта"
        }
      },
      "additionalProperties": false
    },
    "userReturnAddress": {
      "type": "object",
      "description": "Адрес возврата пользователя",
      "properties": {
        "manual-address-input": {
          "type": "boolean",
          "description": "Ручной ввод адреса"
        }
      }
    },
    "shippingPointItem": {
      "type": "object",
      "description": "Информация о точке сдачи",
      "required": [
        "operator-postcode"
      ],
      "properties": {
        "operator-postcode": {
          "type": "string",
          "description": "Индекс почтового отделения обслуживания"
        },
        "additional-operator-postcode": {
          "type": "string",
          "description": "Дополнительный индекс ОПС"
        },
        "additional-operator-postcodes": {
          "type": "array",
          "description": "Список дополнительных индексов ОПС",
          "items": {
            "type": "string"
          }
        },
        "available-mail-types": {
          "type": "array",
          "description": "Доступные виды РПО",
          "items": {
            "type": "string"
          }
        },
        "available-products": {
          "type": "array",
          "description": "Доступные продукты",
          "items": {
            "$ref": "#/definitions/product"
          }
        },
        "courier-call": {
          "type": "boolean",
          "description": "Вызов курьера"
        },
        "enabled": {
          "type": "boolean",
          "description": "Признак активации"
        },
        "is-agreement": {
          "type": "boolean",
          "description": "Договор заключён"
        },
        "ops-address": {
          "type": "string",
          "description": "Адрес ОПС"
        },
        "pre-postal-preparation": {
          "type": "boolean",
          "description": "Предварительная почтовая подготовка"
        },
        "return-address-type": {
          "type": "string",
          "description": "Тип адреса возврата",
          "enum": [
            "POSTOFFICE_ADDRESS",
            "SPECIFIED_ADDRESS"
          ]
        },
        "temporary": {
          "type": "boolean",
          "description": "Временная точка сдачи"
        },
        "user-available-mail-types": {
          "type": "array",
          "description": "Виды РПО, доступные пользователю",
          "items": {
            "type": "string"
          }
        },
        "user-available-products": {
          "type": "array",
          "description": "Продукты, доступные пользователю",
          "items": {
            "$ref": "#/definitions/product"
          }
        },
        "user-return-address": {
          "$ref": "#/definitions/userReturnAddress"
        },
        "vsd-enabled": {
          "type": "boolean",
          "description": "ВСД включён"
        }
      }
    },
    "response": {
      "type": "array",
      "description": "Массив точек сдачи отправлений",
      "items": {
        "$ref": "#/definitions/shippingPointItem"
      }
    }
  },
  "$ref": "#/definitions/response"
}
