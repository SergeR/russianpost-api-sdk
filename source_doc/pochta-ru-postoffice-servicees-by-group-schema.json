{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "pochta-ru-postoffice-by-service-group-schema.json",
  "title": "Почта России - Схема ответа API для получения сервисов по группам",
  "description": "JSON Schema для ответа API Почты России при запросе списка сервисов по группам",
  "definitions": {
    "response": {
      "type": "array",
      "description": "Массив сервисов",
      "items": {
        "type": "object",
        "description": "Информация о сервисе",
        "required": [
          "code",
          "group-id",
          "name"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "Код сервиса (например: 1.2)"
          },
          "group-id": {
            "type": "integer",
            "description": "Внутренний идентификатор группы, которой принадлежит сервис"
          },
          "name": {
            "type": "string",
            "description": "Описание сервиса"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
