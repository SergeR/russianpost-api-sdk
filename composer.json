{
    "name": "serger/russianpost-php-sdk",
    "description": "PHP 8.2 SDK for Russian Post (Почта России) JSON API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11",
        "nyholm/psr7": "^1.8",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^1.12"
    },
    "suggest": {
        "guzzlehttp/guzzle": "PSR-18 HTTP client",
        "symfony/http-client": "PSR-18 HTTP client (with nyholm/psr7)",
        "nyholm/psr7": "Lightweight PSR-7 implementation"
    },
    "autoload": {
        "psr-4": {"SergeR\\RussianPostSDK\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"SergeR\\RussianPostSDK\\Tests\\": "tests/"}
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "stan": "vendor/bin/phpstan analyse src tests --level=8"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
